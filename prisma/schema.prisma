generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// -----Enums-----

enum Booking_Status{
  CONFIRMED
  PENDING
  CHECKED_IN
  CHECKED_OUT
  CANCELLED
}

enum Villa_Status{
  AVAILABLE
  OCCUPIED
  MAINTENANCE
}

enum Expense_Type{
  SPLIT
  INDIVIDUAL
}

enum Expense_Category{
  MAINTENANCE
  CLEANING
  MARKETING
  UTILITIES
  OTHERS
}

enum Amenities{
  WIFI
  POOL
  PARKING
  BEACH_ACCESS
  KITCHEN
  AC
  TV
  BALCONY
}

enum Payment_Status{
  PAID
  PENDING
}

// -----Tables-----

model User {
  id        Int      @id @default(autoincrement())
  firstName String   @db.VarChar(50)
  lastName  String   @db.VarChar(50)
  email     String   @unique @db.VarChar(100)
  password  String   @db.VarChar(255)
  role      Role?     @relation(fields: [roleId], references: [id])
  roleId    Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userPermissions UserPermission[]
}

model Role {
  id              Int              @id @default(autoincrement())
  name            String           @unique
  rolePermissions RolePermission[]
  users           User[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model Permission{
  permissionId    Int              @id @default(autoincrement())
  name            String           @unique
  RolePermission  RolePermission[]
  userPermissions UserPermission[] 
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model RolePermission{
  rolePermissionId Int        @id @default(autoincrement())
  role             Role       @relation(fields: [roleId], references: [id])
  roleId           Int
  permission       Permission @relation(fields: [permissionId], references: [permissionId])
  permissionId     Int
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
}

model UserPermission {
  id           Int        @id @default(autoincrement())
  user         User       @relation(fields: [userId], references: [id])
  userId       Int
  permission   Permission @relation(fields: [permissionId], references: [permissionId])
  permissionId Int
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([userId, permissionId])
}

model VillaImage {
  id      Int    @id @default(autoincrement())
  link    String @db.VarChar(255)
  villa   Villa  @relation(fields: [villaId], references: [id])
  villaId Int
}

model Villa {
  id          Int       @id @default(autoincrement())
  name        String
  location    String    @db.VarChar(255)
  price       Int
  maxGuests   Int
  bedrooms    Int
  bathrooms   Int
  description String    @db.VarChar(500)
  status      Villa_Status
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  amenities   VillaAmenity[]
  images      VillaImage[]
  bookings    Booking[]
  expenses    Expense[]
}


model Amenity {
  id      Int      @id @default(autoincrement())
  name    Amenities
  villas  VillaAmenity[]
}

model VillaAmenity {
  villa     Villa   @relation(fields: [villaId], references: [id])
  villaId   Int
  amenity   Amenity @relation(fields: [amenityId], references: [id])
  amenityId Int

  @@id([villaId, amenityId])
}

model Booking {
  id             Int           @id @default(autoincrement())
  guestName      String        @db.VarChar(100)
  guestEmail     String        @db.VarChar(100)
  guestPhone     String        @db.VarChar(20)
  villa          Villa         @relation(fields: [villaId], references: [id])
  villaId        Int
  checkIn        DateTime
  checkOut       DateTime
  totalGuests    Int
  specialRequest String?       @db.VarChar(500)
  bookingStatus  Booking_Status
  paymentStatus  Payment_Status
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  expenses       BookingExpense[]
}

model Expense {
  id           Int           @id @default(autoincrement())
  title        String        @db.VarChar(100)
  amount       Int
  date         DateTime
  type         Expense_Type
  category     Expense_Category
  villa        Villa?        @relation(fields: [villaId], references: [id])
  villaId      Int?
  bookings     BookingExpense[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model BookingExpense {
  id        Int      @id @default(autoincrement())
  booking   Booking  @relation(fields: [bookingId], references: [id])
  bookingId Int
  expense   Expense  @relation(fields: [expenseId], references: [id])
  expenseId Int
  amount    Int
}