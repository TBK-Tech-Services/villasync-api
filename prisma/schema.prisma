generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model GeneralSetting {
  id           Int      @id @default(autoincrement())
  businessName String   @db.VarChar(255)
  contactEmail String   @db.VarChar(255)
  phoneNumber  String   @db.VarChar(20)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model User {
  id          Int      @id @default(autoincrement())
  firstName   String   @db.VarChar(50)
  lastName    String   @db.VarChar(50)
  email       String   @unique @db.VarChar(100)
  password    String   @db.VarChar(255)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  roleId      Int?
  role        Role?    @relation(fields: [roleId], references: [id])
  ownedVillas Villa[]
}

model Role {
  id              Int              @id @default(autoincrement())
  name            String           @unique
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  rolePermissions RolePermission[]
  users           User[]
}

model Permission {
  permissionId   Int              @id @default(autoincrement())
  name           String           @unique
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  RolePermission RolePermission[]
}

model RolePermission {
  rolePermissionId Int        @id @default(autoincrement())
  roleId           Int
  permissionId     Int
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  permission       Permission @relation(fields: [permissionId], references: [permissionId])
  role             Role       @relation(fields: [roleId], references: [id])
}

model AmenityCategory {
  id          Int       @id @default(autoincrement())
  name        String    @unique @db.VarChar(100)
  description String?   @db.VarChar(255)
  icon        String?   @db.VarChar(50)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  amenities   Amenity[]
}

model Amenity {
  id          Int             @id @default(autoincrement())
  name        String          @db.VarChar(100)
  categoryId  Int             @map("category_id")
  createdAt   DateTime        @default(now())
  description String?         @db.VarChar(255)
  updatedAt   DateTime        @updatedAt
  category    AmenityCategory @relation(fields: [categoryId], references: [id])
  villas      VillaAmenity[]

  @@unique([name, categoryId])
}

model VillaAmenity {
  amenityId Int      @map("amenity_id")
  createdAt DateTime @default(now())
  villaId   Int      @map("villa_id")
  amenity   Amenity  @relation(fields: [amenityId], references: [id], onDelete: Cascade)
  villa     Villa    @relation(fields: [villaId], references: [id], onDelete: Cascade)

  @@id([villaId, amenityId])
}

model Villa {
  id            Int            @id @default(autoincrement())
  name          String         @db.VarChar(100)
  location      String         @db.VarChar(500)
  price         Int
  maxGuests     Int
  bedrooms      Int
  bathrooms     Int
  description   String         @db.VarChar(1000)
  status        Villa_Status
  imageUrl      String         @db.VarChar(500)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  ownerId       Int?
  bookings      Booking[]
  expenses      Expense[]
  expenseVillas ExpenseVilla[]
  owner         User?          @relation(fields: [ownerId], references: [id])
  amenities     VillaAmenity[]
}

model Booking {
  id                 Int              @id @default(autoincrement())
  guestName          String           @db.VarChar(100)
  guestEmail         String?          @db.VarChar(100)
  guestPhone         String           @db.VarChar(20)
  alternatePhone     String?          @db.VarChar(20)
  villaId            Int
  checkIn            DateTime
  checkOut           DateTime
  totalGuests        Int
  numberOfNights     Int
  specialRequest     String?          @db.VarChar(500)
  bookingStatus      Booking_Status   @default(CONFIRMED)
  paymentStatus      Payment_Status   @default(PENDING)
  basePrice          Decimal          @db.Decimal(10, 2)
  customPrice        Decimal?         @db.Decimal(10, 2)
  extraPersonCharge  Decimal          @default(0) @db.Decimal(10, 2)
  discount           Decimal          @default(0) @db.Decimal(10, 2)
  subTotalAmount     Decimal          @db.Decimal(10, 2)
  isGSTIncluded      Boolean          @default(false)
  totalTax           Decimal          @db.Decimal(10, 2)
  totalPayableAmount Decimal          @db.Decimal(10, 2)
  advancePaid        Decimal          @default(0) @db.Decimal(10, 2)
  dueAmount          Decimal          @db.Decimal(10, 2)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  villa              Villa            @relation(fields: [villaId], references: [id], onDelete: Cascade)
  expenses           BookingExpense[]
}

model ExpenseCategory {
  id        Int       @id @default(autoincrement())
  name      String    @db.VarChar(100)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  expenses  Expense[]
}

model Expense {
  id         Int              @id @default(autoincrement())
  title      String           @db.VarChar(100)
  amount     Int
  date       DateTime
  type       Expense_Type
  villaId    Int?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  categoryId Int
  bookings   BookingExpense[]
  category   ExpenseCategory  @relation(fields: [categoryId], references: [id])
  villa      Villa?           @relation(fields: [villaId], references: [id], onDelete: Cascade)
  villas     ExpenseVilla[]
}

model ExpenseVilla {
  id        Int     @id @default(autoincrement())
  expenseId Int
  villaId   Int
  amount    Int
  expense   Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  villa     Villa   @relation(fields: [villaId], references: [id])
}

model BookingExpense {
  id        Int     @id @default(autoincrement())
  bookingId Int
  expenseId Int
  amount    Int
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  expense   Expense @relation(fields: [expenseId], references: [id])
}

enum Booking_Status {
  CONFIRMED
  CHECKED_IN
  CHECKED_OUT
  CANCELLED
}

enum Villa_Status {
  AVAILABLE
  OCCUPIED
  MAINTENANCE
}

enum Expense_Type {
  INDIVIDUAL
  SPLIT
}

enum Payment_Status {
  PAID
  PENDING
}
