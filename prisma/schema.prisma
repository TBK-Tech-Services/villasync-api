// -----Enums-----

enum Booking_Status{
  CONFIRMED
  CHECKED_IN
  CHECKED_OUT
  CANCELLED
}

enum Villa_Status{
  AVAILABLE
  OCCUPIED
  MAINTENANCE
}

enum Expense_Type{
  INDIVIDUAL
  SPLIT
}

enum Payment_Status{
  PAID
  PENDING
}

// -----Tables-----

// Table to store users
model User {
  id        Int      @id @default(autoincrement())
  firstName String   @db.VarChar(50)
  lastName  String   @db.VarChar(50)
  email     String   @unique @db.VarChar(100)
  password  String   @db.VarChar(255)
  role      Role?     @relation(fields: [roleId], references: [id])
  roleId    Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Table to store roles
model Role {
  id              Int              @id @default(autoincrement())
  name            String           @unique
  rolePermissions RolePermission[]
  users           User[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

// Table to store permissions
model Permission{
  permissionId    Int              @id @default(autoincrement())
  name            String           @unique
  RolePermission  RolePermission[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

// Table to store permisisons for a role
model RolePermission{
  rolePermissionId Int        @id @default(autoincrement())
  role             Role       @relation(fields: [roleId], references: [id])
  roleId           Int
  permission       Permission @relation(fields: [permissionId], references: [permissionId])
  permissionId     Int
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
}

// Table to Store Amenity Categories
model AmenityCategory {
  id          Int       @id @default(autoincrement())
  name        String    @unique @db.VarChar(100)
  description String?   @db.VarChar(255)
  icon        String?   @db.VarChar(50)  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  amenities   Amenity[]
}

// Table to Store Individual Amenities
model Amenity {
  id          Int              @id @default(autoincrement())
  name        String           @db.VarChar(100)
  description String?          @db.VarChar(255)
  category    AmenityCategory  @relation(fields: [categoryId], references: [id])
  categoryId  Int              @map("category_id")
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  villas      VillaAmenity[]

  @@unique([name, categoryId])
}

// Junction Table for Villa-Amenity Relationship
model VillaAmenity {
  villa     Villa   @relation(fields: [villaId], references: [id], onDelete: Cascade)
  villaId   Int     @map("villa_id")
  amenity   Amenity @relation(fields: [amenityId], references: [id], onDelete: Cascade)
  amenityId Int     @map("amenity_id")
  createdAt DateTime @default(now())

  @@id([villaId, amenityId])
}

// Table to store Villa Details
model Villa {
  id          Int       @id @default(autoincrement())
  name        String    @db.VarChar(100)
  location    String    @db.VarChar(500)
  price       Int       
  maxGuests   Int       
  bedrooms    Int
  bathrooms   Int
  description String    @db.VarChar(1000)
  status      Villa_Status
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  amenities   VillaAmenity[]
  images      VillaImage[]
  bookings    Booking[]
  expenses    Expense[]
  expenseVillas ExpenseVilla[]
}

// Table to Store Image for Villa
model VillaImage {
  id      Int    @id @default(autoincrement())
  link    String @db.VarChar(255)
  villa   Villa  @relation(fields: [villaId], references: [id], onDelete: Cascade)
  villaId Int    @map("villa_id")
}

// Table to Store Bookings for Villa
model Booking {
  id                 Int            @id @default(autoincrement())
  guestName          String         @db.VarChar(100)
  guestEmail         String         @db.VarChar(100)
  guestPhone         String         @db.VarChar(20)
  villa              Villa          @relation(fields: [villaId], references: [id], onDelete: Cascade)
  villaId            Int
  checkIn            DateTime
  checkOut           DateTime
  totalGuests        Int
  specialRequest     String?        @db.VarChar(500)
  bookingStatus      Booking_Status @default(CONFIRMED)
  paymentStatus      Payment_Status @default(PENDING)
  subTotalAmount     Int
  isGSTIncluded      Boolean        @default(false)
  totalTax           Int
  totalPayableAmount Int
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  expenses           BookingExpense[]
}

// Table to Store Expense Category
model ExpenseCategory {
  id           Int           @id @default(autoincrement())
  name         String        @db.VarChar(100)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  expenses     Expense[]
}

// Table to Store Expenses
model Expense {
  id           Int              @id @default(autoincrement())
  title        String           @db.VarChar(100)
  amount       Int
  date         DateTime
  type         Expense_Type
  category     ExpenseCategory  @relation(fields: [categoryId], references: [id])
  categoryId   Int
  villa        Villa?           @relation(fields: [villaId], references: [id], onDelete: Cascade)
  villaId      Int?
  bookings     BookingExpense[]
  villas       ExpenseVilla[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
}

model ExpenseVilla {
  id        Int     @id @default(autoincrement())
  expense   Expense @relation(fields: [expenseId], references: [id] , onDelete: Cascade)
  expenseId Int
  villa     Villa   @relation(fields: [villaId], references: [id])
  villaId   Int
  amount    Int   
}

model BookingExpense {
  id        Int      @id @default(autoincrement())
  booking   Booking  @relation(fields: [bookingId], references: [id] , onDelete: Cascade)
  bookingId Int
  expense   Expense  @relation(fields: [expenseId], references: [id])
  expenseId Int
  amount    Int
}
