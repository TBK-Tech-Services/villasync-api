generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model GeneralSetting {
  id           Int      @id @default(autoincrement())
  businessName String   @db.VarChar(255)
  contactEmail String   @db.VarChar(255)
  phoneNumber  String   @db.VarChar(20)
  admin1Name   String?  @db.VarChar(100)
  admin1Email  String?  @db.VarChar(255)
  admin1Phone  String?  @db.VarChar(20)
  admin2Name   String?  @db.VarChar(100)
  admin2Email  String?  @db.VarChar(255)
  admin2Phone  String?  @db.VarChar(20)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model User {
  id                   Int      @id @default(autoincrement())
  firstName            String   @db.VarChar(50)
  lastName             String   @db.VarChar(50)
  email                String   @unique @db.VarChar(100)
  password             String   @db.VarChar(255)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  roleId               Int?
  managementFeePercent Decimal  @default(0) @db.Decimal(5, 2)
  role                 Role?    @relation(fields: [roleId], references: [id])
  ownedVillas          Villa[]
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  email     String   @db.VarChar(100)
  otp       String   @db.VarChar(6)
  expiresAt DateTime
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Role {
  id              Int              @id @default(autoincrement())
  name            String           @unique
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  rolePermissions RolePermission[]
  users           User[]
}

model Permission {
  permissionId   Int              @id @default(autoincrement())
  name           String           @unique
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  RolePermission RolePermission[]
}

model RolePermission {
  rolePermissionId Int        @id @default(autoincrement())
  roleId           Int
  permissionId     Int
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  permission       Permission @relation(fields: [permissionId], references: [permissionId])
  role             Role       @relation(fields: [roleId], references: [id])
}

model AmenityCategory {
  id          Int       @id @default(autoincrement())
  name        String    @unique @db.VarChar(100)
  description String?   @db.VarChar(255)
  icon        String?   @db.VarChar(50)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  amenities   Amenity[]
}

model Amenity {
  id          Int             @id @default(autoincrement())
  name        String          @db.VarChar(100)
  categoryId  Int             @map("category_id")
  createdAt   DateTime        @default(now())
  description String?         @db.VarChar(255)
  updatedAt   DateTime        @updatedAt
  category    AmenityCategory @relation(fields: [categoryId], references: [id])
  villas      VillaAmenity[]

  @@unique([name, categoryId])
}

model VillaAmenity {
  amenityId Int      @map("amenity_id")
  createdAt DateTime @default(now())
  villaId   Int      @map("villa_id")
  amenity   Amenity  @relation(fields: [amenityId], references: [id], onDelete: Cascade)
  villa     Villa    @relation(fields: [villaId], references: [id], onDelete: Cascade)

  @@id([villaId, amenityId])
}

model Villa {
  id            Int            @id @default(autoincrement())
  name          String         @db.VarChar(100)
  location      String         @db.VarChar(500)
  bedrooms      Int
  bathrooms     Int
  description   String         @db.VarChar(1000)
  status        Villa_Status
  brochureUrl   String?
  imageUrl      String         @db.VarChar(500)
  images        VillaImage[]  
  managers      VillaManager[]
  caretakers    VillaCaretaker[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  ownerId       Int?
  bookings      Booking[]
  expenses      Expense[]
  expenseVillas ExpenseVilla[]
  owner         User?          @relation(fields: [ownerId], references: [id])
  amenities     VillaAmenity[]
}

model VillaManager {
  id        Int      @id @default(autoincrement())
  phone     String   @db.VarChar(20)
  villaId   Int
  villa     Villa    @relation(fields: [villaId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model VillaCaretaker {
  id        Int      @id @default(autoincrement())
  phone     String   @db.VarChar(20)
  villaId   Int
  villa     Villa    @relation(fields: [villaId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model VillaImage {
  id        Int      @id @default(autoincrement())
  url       String   @db.VarChar(500)
  villaId   Int
  villa     Villa    @relation(fields: [villaId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Booking {
  id                    Int                     @id @default(autoincrement())
  guestName             String                  @db.VarChar(100)
  guestEmail            String?                 @db.VarChar(100)
  guestPhone            String                  @db.VarChar(20)
  alternatePhone        String?                 @db.VarChar(20)
  villaId               Int
  checkIn               DateTime
  checkOut              DateTime
  numberOfAdults        Int                     @default(1)
  numberOfChildren      Int                     @default(0)
  totalGuests           Int
  numberOfNights        Int
  specialRequest        String?                 @db.VarChar(500)
  bookingStatus         Booking_Status          @default(CONFIRMED)
  paymentStatus         Payment_Status          @default(PENDING)
  perNightPrice         Decimal?                @db.Decimal(10, 2)
  customPrice           Decimal?                @db.Decimal(10, 2)
  extraPersonCharge     Decimal                 @default(0) @db.Decimal(10, 2)
  discount              Decimal                 @default(0) @db.Decimal(10, 2)
  agentName             String?                 @db.VarChar(100)
  subTotalAmount        Decimal                 @db.Decimal(10, 2)
  gstMode               String                  @default("NONE") @db.VarChar(20)
  gstOnBasePrice        Boolean                 @default(false)
  gstOnExtraCharge      Boolean                 @default(false)
  gstDays               Int                     @default(0)
  bookingSource         String?                 @db.VarChar(50)
  totalTax              Decimal                 @db.Decimal(10, 2)
  totalPayableAmount    Decimal                 @db.Decimal(10, 2)
  advancePaid           Decimal                 @default(0) @db.Decimal(10, 2)
  dueAmount             Decimal                 @db.Decimal(10, 2)
  voucherApprovalStatus Voucher_Approval_Status @default(NOT_APPROVED)
  voucherApprovedBy     Voucher_Approver?
  voucherApprovedAt     DateTime?
  voucherSentToAdminsAt DateTime?
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  villa                 Villa                   @relation(fields: [villaId], references: [id], onDelete: Cascade)
  expenses              BookingExpense[]
}

model ExpenseCategory {
  id        Int       @id @default(autoincrement())
  name      String    @db.VarChar(100)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  expenses  Expense[]
}

model Expense {
  id         Int              @id @default(autoincrement())
  title      String           @db.VarChar(100)
  amount     Int
  date       DateTime
  type       Expense_Type
  villaId    Int?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  categoryId Int
  bookings   BookingExpense[]
  category   ExpenseCategory  @relation(fields: [categoryId], references: [id])
  villa      Villa?           @relation(fields: [villaId], references: [id], onDelete: Cascade)
  villas     ExpenseVilla[]
}

model ExpenseVilla {
  id        Int     @id @default(autoincrement())
  expenseId Int
  villaId   Int
  amount    Int
  expense   Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  villa     Villa   @relation(fields: [villaId], references: [id])
}

model BookingExpense {
  id        Int     @id @default(autoincrement())
  bookingId Int
  expenseId Int
  amount    Int
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  expense   Expense @relation(fields: [expenseId], references: [id])
}

enum Booking_Status {
  CONFIRMED
  CHECKED_IN
  CHECKED_OUT
  CANCELLED
}

enum Villa_Status {
  AVAILABLE
  OCCUPIED
  MAINTENANCE
}

enum Expense_Type {
  INDIVIDUAL
  SPLIT
}

enum Payment_Status {
  PAID
  PENDING
}

enum Voucher_Approval_Status {
  NOT_APPROVED
  APPROVED
}

enum Voucher_Approver {
  PUJA
  JAIRAJ
}
